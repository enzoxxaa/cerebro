# Obsidian — solo versionar configuración esencial, no los plugins binarios
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css

# Archivos del sistema
.DS_Store
Thumbs.db

# Archivos temporales
*.tmp
*.swp
*~

# Carpetas de sistema
__pycache__/
*.pyc

# Archivos grandes / binarios (no van en git)
*.pdf
*.PDF

# Archivos compilados de LaTeX
*.aux
*.log
*.out
*.synctex.gz
*.fls
*.fdb_latexmk
*.toc
